{
  "name": "@zera/contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js",
      "default": "./dist/config.js"
    },
    "./wallet": {
      "types": "./dist/wallet.d.ts",
      "import": "./dist/wallet.js",
      "default": "./dist/wallet.js"
    },
    "./providers": {
      "types": "./dist/providers.d.ts",
      "import": "./dist/providers.js"
    },
    "./witness": {
      "types": "./dist/witness.d.ts",
      "import": "./dist/witness.js"
    }
  },
  "scripts": {
    "clean": "shx rm -rf dist src/managed",
    "compact:compile": "compact compile src/main.compact src/managed/zera",
    "build": "shx rm -rf dist && tsc --project tsconfig.build.json && shx cp -Rf ./src/managed ./dist/managed && shx cp ./src/main.compact ./dist/",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "cross-env NODE_OPTIONS='--experimental-vm-modules' vitest run",
    "deploy": "cross-env NODE_OPTIONS='--max-old-space-size=4096' npx tsx src/deploy.ts"
  },
  "dependencies": {
    "@midnight-ntwrk/compact-runtime": "0.15.0",
    "@midnight-ntwrk/ledger-v8": "8.0.3",
    "@midnight-ntwrk/midnight-js-contracts": "4.0.2",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "4.0.2",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "4.0.2",
    "@midnight-ntwrk/midnight-js-level-private-state-provider": "4.0.2",
    "@midnight-ntwrk/midnight-js-network-id": "4.0.2",
    "@midnight-ntwrk/midnight-js-node-zk-config-provider": "4.0.2",
    "@midnight-ntwrk/midnight-js-types": "4.0.2",
    "@midnight-ntwrk/midnight-js-utils": "4.0.2",
    "@midnight-ntwrk/wallet-sdk-abstractions": "2.1.0",
    "@midnight-ntwrk/wallet-sdk-facade": "3.0.0",
    "@midnight-ntwrk/wallet-sdk-unshielded-wallet": "2.1.0",
    "dotenv": "^17.4.2",
    "pino": "^9.0.0",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@midnight-ntwrk/midnight-js-compact": "4.0.2",
    "@types/node": "^22.0.0",
    "cross-env": "^10.1.0",
    "pino-pretty": "^13.0.0",
    "shx": "^0.3.4",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}