# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_IPFS_API_URL=http://localhost:8080

# Midnight Network Configuration
# CRITICAL: Set to 'preprod' for Lace wallet to work
# Lace wallet does NOT support 'undeployed' (local) network
NEXT_PUBLIC_MIDNIGHT_NETWORK_ID=preprod

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/zera

# IPFS (Pinata)
PINATA_JWT=your_pinata_jwt_token_here
